import json
import os

BASE_DIR = os.path.dirname(__file__)

def load(file_name):
    path = os.path.join(BASE_DIR, file_name)
    try:
        with open(path, "r") as f:
            return json.load(f)
    except json.JSONDecodeError as e:
        print(f"JSON error in {file_name}: {e}")
        return None 

profile = load("profile.json")
daily = load("daily.json")
streaks = load("streaks.json")

def print_character(profile):
    print("\n-=-Main Character-=-")
    print(f"Name: {profile['name']}")
    print(f"Level: {profile['level']}")

def print_stats(profile):
    print("\n-=-STATS-=-")
    for stat, value in profile['stats'].items():
        print (stat, ":", value)

def print_tasks(daily):
    print("\n-=-TASKS-=-")
    for task in daily['tasks']:
        status = "DONE" if task["completed"] else "NOT DONE"
        print(f"- {task['name']}, {task['duration_minutes']} minutes, {status}")
    
def print_streaks(streaks):
    print("\n-=-STREAKS-=-")
    for streak in streaks['goals']:
        print(f"Name: {streak['name']}: {streak['daystreak']} days \nType: {streak['type']} \nStatus: {streak['status']} \nProgress {streak['progress']}")

def user_choice(prompt, valid_choices):
    
    while True:
        choice = input(prompt).strip().lower()
        if choice in valid_choices:
            return choice
        else: 
            print(f"Invalid choice! Choose from: {", ".join(valid_choices)}")



print_character(profile)
print_stats(profile)
print_tasks(daily)
print_streaks(streaks)

def action():
    section = user_choice("""Which section would you like to update?
1. Character
2. Daily Challanges
3. Streaks
> """,
["1", "2", "3"])
    
